---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import Icon from '../components/Icon.astro';

const competences = await getCollection('competences');

const techCompetences = competences.filter(c => c.data.category === 'technique').sort((a, b) => b.data.level - a.data.level);
const humanCompetences = competences.filter(c => c.data.category === 'humaine').sort((a, b) => b.data.level - a.data.level);

---

<BaseLayout
	title="Mes Compétences | Martin OUEDRAOGO"
	description="Découvrez mes compétences techniques et humaines"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Mes Compétences"
				tagline="Un équilibre entre expertise technique solide et savoir-être indispensable en entreprise."
				align="start"
			/>
			
			<section class="chart-section">
				<h3>Profil de compétences</h3>
				<div class="chart-container">
					<div class="skills-bars">
						<h4>Compétences Techniques</h4>
						{techCompetences.map(comp => (
							<div class="skill-bar-wrapper">
								<div class="skill-info">
									<span class="skill-name">{comp.data.icon} {comp.data.title}</span>
									<span class="skill-level">{comp.data.level}/10</span>
								</div>
								<div class="progress-bar">
									<div class="progress" style={`width: ${comp.data.level * 10}%`}></div>
								</div>
							</div>
						))}
					</div>
					<div class="skills-bars">
						<h4>Compétences Humaines</h4>
						{humanCompetences.map(comp => (
							<div class="skill-bar-wrapper">
								<div class="skill-info">
									<span class="skill-name">{comp.data.icon} {comp.data.title}</span>
									<span class="skill-level">{comp.data.level}/10</span>
								</div>
								<div class="progress-bar">
									<div class="human-progress progress" style={`width: ${comp.data.level * 10}%`}></div>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<section class="details-section">
				<h3>Détail par domaine</h3>
				<Grid variant="small">
					{competences.map((comp) => (
						<li class="competence-card">
							<a href={`/competences/${comp.id}`} class="card-link">
								<div class="card-header">
									<span class="card-icon">{comp.data.icon}</span>
									<h4 class="card-title">{comp.data.title}</h4>
								</div>
								<p class="card-desc">{comp.data.shortDescription}</p>
								<div class="card-footer">
									<span class="category-tag">{comp.data.category === 'technique' ? 'Technique' : 'Humaine'}</span>
									<span class="level-indicator">Niv. {comp.data.level}/10</span>
								</div>
							</a>
						</li>
					))}
				</Grid>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.chart-section {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding: 2.5rem;
		background-color: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
	}

	.chart-section h3, .details-section h3 {
		font-size: var(--text-2xl);
		color: var(--gray-0);
		text-align: center;
		margin-bottom: 1rem;
	}

	.chart-container {
		display: grid;
		gap: 3rem;
	}

	@media (min-width: 50em) {
		.chart-container {
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
		}
	}

	.skills-bars h4 {
		font-size: var(--text-lg);
		color: var(--gray-200);
		margin-bottom: 1.5rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.skill-bar-wrapper {
		margin-bottom: 1.2rem;
	}

	.skill-info {
		display: flex;
		justify-content: space-between;
		margin-bottom: 0.4rem;
		font-size: var(--text-md);
		color: var(--gray-100);
	}

	.progress-bar {
		height: 8px;
		background-color: var(--gray-800);
		border-radius: 4px;
		overflow: hidden;
	}

	.progress {
		height: 100%;
		background: var(--gradient-accent);
		border-radius: 4px;
		transition: width 1s ease-in-out;
	}
	
	.human-progress {
		background: linear-gradient(to right, var(--gray-400), var(--gray-100));
	}

	.details-section {
		margin-top: 2rem;
	}

	.competence-card {
		list-style: none;
		display: flex;
		flex-direction: column;
		height: 100%;
		background-color: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		transition: transform var(--theme-transition), box-shadow var(--theme-transition);
	}

	.competence-card:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-md);
		border-color: var(--accent-regular);
	}

	.card-link {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		height: 100%;
		text-decoration: none;
		color: inherit;
	}

	.card-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.card-icon {
		font-size: 1.5rem;
	}

	.card-title {
		font-size: var(--text-lg);
		color: var(--gray-100);
		margin: 0;
	}

	.card-desc {
		color: var(--gray-400);
		font-size: var(--text-sm);
		flex-grow: 1;
		margin-bottom: 1.5rem;
	}

	.card-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: var(--text-sm);
		margin-top: auto;
	}

	.category-tag {
		background-color: var(--gray-800);
		color: var(--gray-300);
		padding: 0.2rem 0.6rem;
		border-radius: 99rem;
		font-size: 0.75rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.level-indicator {
		font-weight: bold;
		color: var(--accent-regular);
	}
</style>
