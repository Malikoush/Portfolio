---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
---

<BaseLayout
  title="Contact | Martin OUEDRAOGO"
  description="Me contacter pour une opportunite ou un echange"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Contact"
        tagline="Interesse(e) par mon profil ? N'hesitez pas a me laisser un message ou a me retrouver sur les reseaux professionnels."
        align="start"
      />

      <section class="contact-section">
        <div class="contact-grid">
          <div class="contact-info box">
            <h3>Informations</h3>
            <ul class="info-list">
              <li>
                <Icon icon="paper-plane-tilt" size="1.5rem" /> ouedraogomartin12@yahoo.fr
              </li>
              <li>
                <Icon icon="map-pin" size="1.5rem" /> Region Parisienne, France
              </li>
              <li>
                <a
                  href="https://www.linkedin.com/in/martin-ouedraogo-213a34229/"
                  class="social-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon icon="linkedin-logo" size="1.5rem" /> LinkedIn
                </a>
              </li>
              <li>
                <a
                  href="https://github.com/Malikoush"
                  class="social-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon icon="github-logo" size="1.5rem" /> GitHub
                </a>
              </li>
            </ul>
          </div>

          <div class="contact-form-container box">
            <h3>Envoyez-moi un message</h3>
            <form
              class="contact-form"
              action="https://formspree.io/f/xwvrynvq"
              method="POST"
            >
              <input
                type="hidden"
                name="_subject"
                value="Nouveau message depuis le portfolio"
              />
              <input
                type="text"
                name="_gotcha"
                class="honeypot"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
              />

              <div class="form-group">
                <label for="name">Nom</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Votre nom complet"
                />
              </div>

              <div class="form-group">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="votre.email@exemple.com"
                />
              </div>

              <div class="form-group">
                <label for="subject">Sujet</label>
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  required
                  placeholder="L'objet de votre message"
                />
              </div>

              <div class="form-group">
                <label for="message">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  placeholder="Votre message detaille ici..."></textarea>
              </div>

              <button type="submit" class="submit-btn">
                Envoyer le message
                <Icon icon="paper-plane-tilt" size="1.2em" />
              </button>
            </form>
          </div>
        </div>
      </section>
    </main>
    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .contact-section {
    margin-top: 2rem;
  }

  .contact-grid {
    display: grid;
    gap: 3rem;
  }

  .box {
    border: 1px solid var(--gray-800);
    border-radius: 1.5rem;
    padding: 2.5rem;
    background-color: var(--gray-999_40);
    box-shadow: var(--shadow-sm);
  }

  .box h3 {
    font-size: var(--text-xl);
    color: var(--gray-0);
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--gray-800);
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-list li {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--gray-200);
    font-size: var(--text-lg);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--accent-regular);
    text-decoration: none;
    transition: color var(--theme-transition);
  }

  .social-link:hover,
  .social-link:focus {
    color: var(--accent-text-over);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  label {
    color: var(--gray-200);
    font-size: var(--text-md);
    font-weight: 500;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--gray-800);
    background-color: var(--gray-999);
    color: var(--gray-100);
    font-family: inherit;
    font-size: var(--text-md);
    transition:
      border-color var(--theme-transition),
      box-shadow var(--theme-transition);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent-regular);
    box-shadow: 0 0 0 2px var(--accent-subtle-overlay);
  }

  textarea {
    resize: vertical;
  }

  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    border: none;
    border-radius: 999rem;
    background-color: var(--accent-regular);
    color: var(--accent-text-over);
    font-size: var(--text-md);
    font-weight: bold;
    cursor: pointer;
    transition:
      background-color var(--theme-transition),
      transform var(--theme-transition);
    margin-top: 1rem;
  }

  .submit-btn:hover,
  .submit-btn:focus {
    background-color: var(--accent-dark);
    transform: translateY(-2px);
  }

  @media (min-width: 50em) {
    .contact-grid {
      grid-template-columns: 1fr 2fr;
      gap: 4rem;
    }

    .info-list li {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
