---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';

export async function getStaticPaths() {
	const competences = await getCollection('competences');
	return competences.map((comp) => ({
		params: { slug: comp.id },
	}));
}

const { slug } = Astro.params;
const allCompetences = await getCollection('competences');
const comp = allCompetences.find((c) => c.id === slug);
if (!comp) throw new Error(`Compétence introuvable: ${slug}`);

// use Astro's render helper to obtain a Content component
const { Content } = await render(comp);


const allRealisations = await getCollection('realisations');
const relatedRealisations = allRealisations.filter(real => 
	comp.data.relatedRealisations?.includes(real.id)
);
---

<BaseLayout title={`${comp.data.title} | Compétences | Martin OUEDRAOGO`} description={comp.data.shortDescription}>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/competences/"><Icon icon="arrow-left" /> Compétences</a>
					<Hero title={comp.data.title} align="start">
						<div class="details">
							<div class="tags">
								<div class="pill">{comp.data.icon} {comp.data.category === 'technique' ? 'Technique' : 'Humaine'}</div>
								<div class="pill level">Niveau {comp.data.level}/10</div>
							</div>
							<p class="description">{comp.data.shortDescription}</p>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content">
					<div class="content-body">
					<Content />
					
					{relatedRealisations.length > 0 && (
						<section class="related-section">
							<h3>Réalisations liées à cette compétence</h3>
							<ul class="related-list">
								{relatedRealisations.map((real) => (
									<li>
										<a href={`/realisations/${real.id}`} class="related-link">
											<Icon icon="arrow-right" />
											{real.data.title}
										</a>
									</li>
								))}
							</ul>
						</section>
					)}
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--gray-300);
		text-decoration: none;
		font-size: var(--text-sm);
		transition: color var(--theme-transition);
	}

	.back-link:hover,
	.back-link:focus {
		color: var(--gray-0);
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.pill {
		display: flex;
		padding: 0.5rem 1rem;
		gap: 0.5rem;
		color: var(--accent-text-over);
		border: 1px solid var(--accent-regular);
		background-color: var(--accent-regular);
		border-radius: 999rem;
		font-size: var(--text-md);
		line-height: 1.35;
		white-space: nowrap;
	}
	
	.pill.level {
		background-color: transparent;
		color: var(--accent-regular);
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.content {
		max-width: 65ch;
		margin-inline: auto;
	}
	
	.content-body > :global(*) {
		margin-bottom: 1.5rem;
	}

	.content-body :global(h2) {
		font-size: var(--text-2xl);
		color: var(--gray-0);
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid var(--gray-800);
		padding-bottom: 0.5rem;
	}
	
	.content-body :global(h3) {
		font-size: var(--text-xl);
		color: var(--gray-100);
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	.content-body :global(p) {
		color: var(--gray-300);
		line-height: 1.7;
	}

	.content-body :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
		color: var(--accent-regular);
	}

	.content-body :global(a:hover),
	.content-body :global(a:focus) {
		text-decoration-color: currentColor;
	}
	
	.content-body :global(ul) {
		padding-left: 1.5rem;
		color: var(--gray-300);
		margin-bottom: 1.5rem;
	}
	
	.content-body :global(li) {
		margin-bottom: 0.5rem;
	}

	.content-body :global(strong) {
		color: var(--gray-100);
	}

	.related-section {
		margin-top: 4rem;
		padding: 2rem;
		background-color: var(--gray-999_40);
		border-radius: 1.5rem;
		border: 1px solid var(--gray-800);
	}

	.related-section h3 {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin-bottom: 1.5rem;
	}

	.related-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.related-link {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: var(--gray-200);
		text-decoration: none;
		font-size: var(--text-lg);
		transition: color var(--theme-transition), transform var(--theme-transition);
		padding: 0.5rem;
		border-radius: 0.5rem;
	}

	.related-link:hover {
		color: var(--accent-regular);
		transform: translateX(10px);
		background-color: var(--gray-999);
	}

	@media (min-width: 50em) {
		.back-link {
			display: block;
			align-self: flex-start;
		}

		.details {
			flex-direction: row;
			gap: 2.5rem;
		}

		.content :global(blockquote) {
			font-size: var(--text-lg);
		}
	}
</style>
